# =====================================================================
# Trading Research Agent — Environment Variables
# All variables are OPTIONAL. Agent runs without any of them.
# Copy this file to .env and fill in values you want to enable.
# =====================================================================

# ---- Telegram Notifications (optional) ------------------------------
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID — send /start to your bot and check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ---- FRED API (free, recommended) -----------------------------------
# Register at https://fred.stlouisfed.org/docs/api/api_key.html
# Enables: CPI, PCE, Fed funds rate, unemployment, GDP, M2, yield curve
FRED_API_KEY=

# ---- CryptoPanic (free tier) ----------------------------------------
# Register at https://cryptopanic.com/developers/api/
# Enables: crypto-specific news with community sentiment votes
CRYPTOPANIC_API_KEY=

# ---- Reddit Sentiment (optional, free) ------------------------------
# Register at https://www.reddit.com/prefs/apps (script type)
# Enables: r/wallstreetbets, r/stocks, r/investing, r/CryptoCurrency sentiment
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingResearchAgent/1.0

# ---- Agent Behavior -------------------------------------------------
# How many hours between full runs in --schedule mode (default: 4)
SCHEDULE_INTERVAL_HOURS=4
# How many minutes between alert checks in --schedule mode (default: 30)
ALERT_CHECK_INTERVAL_MINUTES=30
# Timezone for report timestamps (default: Asia/Kolkata)
TIMEZONE=Asia/Kolkata
# Max retries on rate limit (default: 3)
MAX_RETRIES=3
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# ---- Chart Analysis Engine (--chart mode) ---------------------------
# REQUIRED to use: python luna.py --chart "C:/charts/NVDA_4h.png"
#
# OPTION 1: Anthropic Claude (PRIMARY — recommended)
# Get your API key at: https://console.anthropic.com/
# Best-in-class vision reasoning with claude-opus-4-5
ANTHROPIC_API_KEY=
#
# CLAUDE MODEL (optional — defaults to claude-opus-4-5)
# CLAUDE_CHART_MODEL=claude-opus-4-5           (most capable, recommended)
# CLAUDE_CHART_MODEL=claude-3-5-sonnet-latest  (faster, still excellent)
#
# OPTION 2: Google Gemini Vision (secondary fallback — free tier)
# Get your free API key at: https://aistudio.google.com/apikey
# Used automatically if ANTHROPIC_API_KEY is not set
GEMINI_API_KEY=
#
# OPTION 3: OpenAI GPT-4o Vision (tertiary fallback — paid)
# Get your API key at: https://platform.openai.com/api-keys
# Used automatically if neither Claude nor Gemini key is configured
OPENAI_API_KEY=
